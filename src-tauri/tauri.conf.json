{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orquesta Terminal",
  "version": "0.1.14",
  "identifier": "com.orquesta.terminal",
  "build": {
    "beforeDevCommand": "fuser -k 3001/tcp 2>/dev/null; npm run next-dev",
    "beforeBuildCommand": "npm run next-build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../src-tauri/webview-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Orquesta Terminal",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://getorquesta.com https://ws.orquesta.live https://apumail.com https://sudosudo.dev https://rogerthat.chat https://trustops.eu"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/512x512.png",
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/32x32.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "2024 Orquesta",
    "category": "DeveloperTool",
    "shortDescription": "Standalone terminal workspace for AI-powered development",
    "longDescription": "Run multiple AI coding assistants side-by-side in a single workspace."
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {}
  }
}
